# ─── Sanity ──────────────────────────────────────────────────────────────────
# Get these from sanity.io/manage after creating your project.
# The project ID is on your project's settings page.
VITE_SANITY_PROJECT_ID=your-project-id-here

# Dataset name. Use "production" unless you know you want something else.
VITE_SANITY_DATASET=production

# API version. Leave as today's date in YYYY-MM-DD format.
VITE_SANITY_API_VERSION=2026-05-16

# Read-only token. Only required if your dataset is private. Leave blank
# for a public dataset (recommended for a public website).
VITE_SANITY_READ_TOKEN=

# ─── Analytics ───────────────────────────────────────────────────────────────
# Google Analytics 4 measurement ID, format G-XXXXXXXXXX.
# Leave blank to disable analytics entirely. Analytics also requires the
# user to accept analytics cookies; until they do, GA never loads.
VITE_GA4_MEASUREMENT_ID=

# ─── Site URL ────────────────────────────────────────────────────────────────
# Used for canonical URLs, sitemap, and structured data. No trailing slash.
VITE_SITE_URL=https://htss.org
